# LLM providers
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# LangSmith tracing
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=healthcare-provider-rag

# Database
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/ragdb

# Redis
REDIS_URL=redis://:secret@localhost:6379/0

# Admin
ADMIN_KEY=change_me_in_production

# Application
APP_ENV=development
LOG_LEVEL=INFO
APP_VERSION=1.0.0

# Feature flags
HYDE_ENABLED=false
QUERY_KILLSWITCH=false

# Limits
MAX_DAILY_TOKENS=5000000
CACHE_TTL_SECONDS=86400
MAX_SESSION_QUERIES=50
RATE_LIMIT_PER_MINUTE=10
SIMILARITY_CUTOFF=0.5
CACHE_SIMILARITY_THRESHOLD=0.97
RETRIEVE_TOP_K=20
RERANK_TOP_K=5
MAX_QUERY_TOKENS=500
MAX_OUTPUT_TOKENS=1500

# CORS
ALLOWED_ORIGINS=http://localhost:8501

# OTLP
OTLP_ENDPOINT=http://localhost:4317
